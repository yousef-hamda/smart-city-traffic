{
  "consumer": {
    "name": "api-gateway"
  },
  "interactions": [
    {
      "description": "a demand forecast request",
      "providerStates": [
        {
          "name": "segment jaffa-road-00 exists"
        }
      ],
      "request": {
        "body": {
          "horizon_hours": 6,
          "segment_id": "jaffa-road-00"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "method": "POST",
        "path": "/forecast/demand"
      },
      "response": {
        "body": {
          "model_version": "demand-xgboost-v1",
          "predictions": [
            {
              "hour": 8,
              "vehicle_count": 42.5
            }
          ]
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.model_version": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.predictions": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.predictions[*].hour": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.predictions[*].vehicle_count": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "decimal"
                }
              ]
            }
          },
          "header": {},
          "status": {}
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "13.2.0"
    },
    "pactRust": {
      "ffi": "0.4.22",
      "models": "1.2.3"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "ml-prediction"
  }
}
