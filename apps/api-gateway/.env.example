# HTTP port the gateway listens on
PORT=8080

# PostgreSQL/TimescaleDB connection string (used from Phase 2 onwards)
DATABASE_URL=postgresql://traffic:traffic@localhost:5432/traffic

# Redis connection string (caching, rate limiting — Phase 9)
REDIS_URL=redis://localhost:6379

# JWT signing secrets (auth lands in Phase 9 — generate strong random values)
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh

# OTLP gRPC endpoint; tracing is disabled when unset
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
