{
  "name": "@smart-city/api-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Single public entry point — REST + GraphQL Federation, JWT/RBAC auth, API keys",
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "prisma:generate": "prisma generate",
    "test:e2e": "jest --config test/jest-e2e.json"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/graphql": "^12.2.0",
    "@nestjs/apollo": "^12.2.0",
    "@apollo/server": "^4.11.0",
    "@apollo/subgraph": "^2.9.0",
    "graphql": "^16.9.0",
    "@prisma/client": "^5.19.0",
    "@smart-city/shared-types": "workspace:*",
    "@opentelemetry/auto-instrumentations-node": "^0.48.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.52.0",
    "@opentelemetry/sdk-node": "^0.52.0",
    "ioredis": "^5.4.1",
    "argon2": "^0.40.3",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1",
    "nestjs-pino": "^4.1.0",
    "pino-http": "^10.3.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/testing": "^10.4.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/passport": "^1.0.16",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "pino-pretty": "^11.2.0",
    "prisma": "^5.19.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "typescript": "~5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/test"
    ],
    "testRegex": ".*\\.(e2e-)?spec\\.ts$",
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts"
    ],
    "moduleNameMapper": {
      "^@prisma/client$": "<rootDir>/src/__mocks__/prisma-client.mock.ts"
    },
    "globals": {
      "ts-jest": {
        "tsconfig": "<rootDir>/tsconfig.json"
      }
    }
  }
}
