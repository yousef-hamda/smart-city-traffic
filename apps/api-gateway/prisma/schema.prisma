// Hand-written schema mirroring V1__extensions_and_schema.sql
// No db pull — geometry columns use Unsupported("geometry")

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

model Neighborhood {
  id      String  @id
  nameEn  String  @map("name_en")
  nameHe  String? @map("name_he")
  nameAr  String? @map("name_ar")
  polygon Unsupported("geometry")?

  roadSegments RoadSegment[]

  @@map("neighborhoods")
}

model RoadSegment {
  id             String  @id
  roadId         String? @map("road_id")
  seq            Int?
  nameEn         String  @map("name_en")
  nameHe         String? @map("name_he")
  nameAr         String? @map("name_ar")
  segmentType    String? @map("segment_type")
  speedLimitKmh  Int?    @map("speed_limit_kmh")
  lanes          Int?
  neighborhoodId String? @map("neighborhood_id")
  geometry       Unsupported("geometry")?

  neighborhood       Neighborhood?        @relation(fields: [neighborhoodId], references: [id])
  sensors            Sensor[]
  cameras            Camera[]
  predictions        Prediction[]
  signalRecos        SignalRecommendation[]
  incidents          Incident[]

  @@map("road_segments")
}

model Sensor {
  id          String   @id
  sensorType  String?  @map("sensor_type")
  segmentId   String?  @map("segment_id")
  location    Unsupported("geometry")?
  installedAt DateTime? @map("installed_at")
  active      Boolean   @default(true)

  segment RoadSegment? @relation(fields: [segmentId], references: [id])

  @@map("sensors")
}

model Camera {
  id               String  @id
  segmentId        String? @map("segment_id")
  location         Unsupported("geometry")?
  rtspUrl          String? @map("rtsp_url")
  directionDegrees Int?    @map("direction_degrees")
  active           Boolean @default(true)

  segment RoadSegment? @relation(fields: [segmentId], references: [id])

  @@map("cameras")
}

model Prediction {
  id                       String    @id
  segmentId                String?   @map("segment_id")
  predictedAt              DateTime? @map("predicted_at")
  predictionHorizonMinutes Int?      @map("prediction_horizon_minutes")
  predictedVehicleCount    Int?      @map("predicted_vehicle_count")
  predictedAvgSpeedKmh     Float?    @map("predicted_avg_speed_kmh")
  lowerCi                  Float?    @map("lower_ci")
  upperCi                  Float?    @map("upper_ci")
  shapTop5                 Json?     @map("shap_top5")
  modelVersion             String?   @map("model_version")

  segment RoadSegment? @relation(fields: [segmentId], references: [id])

  @@map("predictions")
}

model SignalRecommendation {
  id                  String    @id
  intersectionId      String?   @map("intersection_id")
  segmentId           String?   @map("segment_id")
  recommendedAt       DateTime? @map("recommended_at")
  phaseTimings        Json?     @map("phase_timings")
  expectedThroughput  Float?    @map("expected_throughput")
  agentVersion        String?   @map("agent_version")

  segment RoadSegment? @relation(fields: [segmentId], references: [id])

  @@map("signal_recommendations")
}

model Incident {
  id             String    @id
  segmentId      String?   @map("segment_id")
  incidentType   String?   @map("incident_type")
  severity       String?
  source         String?
  reporterUserId String?   @map("reporter_user_id")
  detectedAt     DateTime? @map("detected_at")
  resolvedAt     DateTime? @map("resolved_at")
  description    String?

  segment RoadSegment? @relation(fields: [segmentId], references: [id])

  @@map("incidents")
}

model Alert {
  id             String    @id
  segmentId      String?   @map("segment_id")
  alertType      String?   @map("alert_type")
  severity       String?
  message        String?
  payload        Json?
  createdAt      DateTime? @map("created_at")
  acknowledgedAt DateTime? @map("acknowledged_at")

  @@map("alerts")
}

model User {
  id           String   @id
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         String   @default("viewer")
  locale       String   @default("en")
  createdAt    DateTime @default(now()) @map("created_at")

  refreshTokens RefreshToken[]
  apiKeys       ApiKey[]

  @@map("users")
}

model RefreshToken {
  id        String   @id
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model ApiKey {
  id             String    @id
  userId         String?   @map("user_id")
  keyHash        String    @unique @map("key_hash")
  name           String?
  scopes         Json      @default("[]")
  quotaPerMinute Int       @default(60) @map("quota_per_minute")
  createdAt      DateTime  @default(now()) @map("created_at")
  expiresAt      DateTime? @map("expires_at")
  active         Boolean   @default(true)

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}
