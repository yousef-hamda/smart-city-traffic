# sensor-ingestion environment variables (Phase 1 skeleton).
# Copy to .env and adjust. Variables marked "Phase 2" are not consumed yet.

# Phase 2 — PostGIS datasource for geo-enrichment
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/smartcity

# Phase 2 — Kafka producer for enriched sensor events
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Phase 2 — MQTT broker for raw sensor payloads
MQTT_BROKER_URL=tcp://localhost:1883

# OpenTelemetry OTLP collector endpoint. The OTel SDK is disabled by default;
# set OTEL_SDK_DISABLED=false together with this endpoint to enable export.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SDK_DISABLED=false
