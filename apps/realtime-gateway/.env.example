# HTTP/WebSocket port
PORT=8088

# Kafka brokers (event fan-out lands in Phase 10)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Redis connection string (Socket.IO adapter for horizontal scaling — Phase 10)
REDIS_URL=redis://localhost:6379

# JWT access-token secret for socket handshake auth (Phase 10)
JWT_ACCESS_SECRET=change-me-access

# OTLP gRPC endpoint; tracing is disabled when unset
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
