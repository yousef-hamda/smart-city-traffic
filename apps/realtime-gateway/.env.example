# HTTP/WebSocket port
PORT=8088

# Kafka brokers the gateway consumes for live fan-out
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_CONSUMER_GROUP=realtime-gateway

# Redis connection string (Socket.IO adapter for horizontal scaling; optional)
REDIS_URL=redis://localhost:6379/3

# JWT access-token secret — must match the API gateway's JWT_ACCESS_SECRET
JWT_ACCESS_SECRET=dev_access_secret_change_me

# Allowed browser origin for CORS
CORS_ORIGIN=http://localhost:3000

# Interval between global-stats broadcasts
GLOBAL_STATS_INTERVAL_MS=5000

# OTLP gRPC endpoint; tracing is disabled when unset
OTEL_EXPORTER_OTLP_ENDPOINT=
